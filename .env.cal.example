# ─── Cal.com Self-hosted Configuration ───────────────────────
# Copy this file to .env.cal and fill in the values.
# Run: cp .env.cal.example .env.cal
#
# Generate secrets:
#   openssl rand -base64 32  → CAL_NEXTAUTH_SECRET
#   openssl rand -base64 24  → CAL_ENCRYPTION_KEY

# PostgreSQL password for the calcom database user
CAL_POSTGRES_PASSWORD=changeme

# NextAuth.js secret (generate with: openssl rand -base64 32)
CAL_NEXTAUTH_SECRET=changeme-generate-with-openssl-rand-base64-32

# Cal.com encryption key (generate with: openssl rand -base64 24)
CAL_ENCRYPTION_KEY=changeme-generate-with-openssl-rand-base64-24

# Public URL of the self-hosted Cal.com instance
# In production, set this to your domain (e.g., https://cal.yourdomain.com)
CAL_PUBLIC_URL=http://localhost:3001

# Cal.com username (used in booking links like username/event-type)
CAL_USERNAME=astrokalki