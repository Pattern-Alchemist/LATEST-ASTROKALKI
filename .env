# ─── Database (Supabase PostgreSQL) ───────────────────────────────
# Uses POSTGRES_PRISMA_URL for connection pooling, POSTGRES_URL_NON_POOLING for migrations
DATABASE_URL="file:./dev.db"

# ─── Email (Resend preferred) ────────────────────────────────────────
# RESEND_API_KEY=re_xxx
EMAIL_FROM="AstroKalki <hello@astrokalki.local>"
ADMIN_EMAIL="admin@astrokalki.local"

# ─── SMTP fallback (when Resend is unset) ────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ─── Admin authentication ────────────────────────────────────────────
ADMIN_PASSWORD="dev-admin-password-2026"
ADMIN_SESSION_SECRET="dev-session-secret-change-in-production"
CRON_SECRET="dev-cron-secret"

# ─── Stripe ──────────────────────────────────────────────────────────
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── Daily.co (video rooms) ──────────────────────────────────────────
# DAILY_API_KEY=xxx
# DAILY_DOMAIN=astrokalki

# ─── Site URL ────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
